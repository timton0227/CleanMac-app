<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	Deliberately empty: CleanMac ships non-sandboxed (§3 — the App Store
	sandbox cannot host a disk cleaner) with the hardened runtime and no
	extra capabilities. Full Disk Access is a user grant via TCC, not an
	entitlement. When Infra A lands, the SMAppService helper registration
	entitlements are added here.
	-->
</dict>
</plist>
