<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.cleanmac.helper</string>
	<!-- SMAppService daemon: program path is relative to the app bundle. -->
	<key>BundleProgram</key>
	<string>Contents/MacOS/CleanHelper</string>
	<!-- launchd starts the daemon on demand for this mach service; the app
	     connects with NSXPCConnection(machServiceName:options:.privileged). -->
	<key>MachServices</key>
	<dict>
		<key>com.cleanmac.helper</key>
		<true/>
	</dict>
	<!-- Ties the daemon to CleanMac in System Settings → Login Items. -->
	<key>AssociatedBundleIdentifiers</key>
	<array>
		<string>com.cleanmac.CleanMac</string>
	</array>
</dict>
</plist>
